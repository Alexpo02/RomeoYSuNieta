  lines:
  - speakerName: Cuervo
    text: "Gracias, ahora lo veo un poco m\xE1s claro."
    portrait: 1
  - speakerName: Musa
    text: "\xBFPor qu\xE9 la casa est\xE1 as\xED? \xBFD\xF3nde est\xE1 mi padre?
      \xBFT\xFA lo sabes?"
    portrait: 0
